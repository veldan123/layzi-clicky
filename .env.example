# ─── Database (PostgreSQL — Neon recommended) ─────────────────────────────────
# Sign up at https://neon.tech (free tier available).
# Use the standard connection string (Neon provides one from your project dashboard).
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Optional: direct (non-pooled) URL for migrations
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Keys from your Stripe dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# This one is also exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Sign up at https://resend.com. Get your API key from Settings → API Keys.
RESEND_API_KEY="re_..."
# The "from" address must be from a domain you verify in Resend.
# For testing you can use: onboarding@resend.dev
EMAIL_FROM="Layzi Clicky <orders@yourdomain.com>"

# ─── Admin auth ───────────────────────────────────────────────────────────────
# Your admin login credentials for the /admin dashboard.
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="choose-a-strong-password"
# Random 32+ character secret for signing session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your-super-secret-key-at-least-32-characters-long"

# ─── Vercel Blob (product image uploads) ──────────────────────────────────────
# Automatically set by Vercel when you add Blob storage in your project settings.
# For local dev: create a .env.local with a token from your Vercel project.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
